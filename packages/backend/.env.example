# Database
DATABASE_URL="postgresql://sdlc:sdlc_password@localhost:5432/sdlc_hub?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV=development

# Encryption (for integration token storage)
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"

# Notifications
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ── LLM Providers (Agent Workflow Automation v4) ──────────────────────────
# Set at least one to enable real LLM-powered agents.
# If none are set, agents run in simulation mode (returns placeholder output).

# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI ChatGPT
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Azure OpenAI (GitHub Copilot uses Azure under the hood)
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Which provider to use by default when agent profile doesn't specify one
# Options: claude | openai | azure | simulate
DEFAULT_LLM_PROVIDER=claude
